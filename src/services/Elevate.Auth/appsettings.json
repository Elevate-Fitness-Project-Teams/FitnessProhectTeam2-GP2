{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=ElevateAuthDb;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "MY_SUPER_SECRET_JWT_KEY_PLACEHOLDER_THAT_IS_LONG_ENOUGH",
    "Issuer": "ElevateAuthService",
    "Audience": "ElevateFitnessApp",
    "ExpiryInMinutes": 10
  },
  "MessageBroker": {
    "Host": "localhost"
  }
}